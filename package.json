{
  "name": "aap-sanity",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "start": "NODE_ENV=production node dist/index.cjs",
    "dev": "nodemon -e ts,tsx --exec \"yarn build && NODE_ENV=development node --enable-source-maps dist/index.cjs\" | pino-pretty",
    "build": "esbuild src/index.ts --bundle --loader:.png=dataurl --outfile=dist/index.cjs --platform=node --sourcemap --minify",
    "prepare": "husky",
    "test": "vitest --run",
    "gentypes": "openapi-typescript http://localhost:8082/openapi.json -o src/types/schema.d.ts"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,css}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "prettier": "@navikt/aap-felles-prettier",
  "dependencies": {
    "@navikt/aap-felles-utils": "^5.6.3",
    "@navikt/aap-sanity-schema-types": "^0.1.2",
    "@navikt/oasis": "^4.1.4",
    "@navikt/pino-logger": "^5.0.0",
    "@portabletext/react": "^6.0.3",
    "@sanity/client": "^7.22.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "groq": "^5.20.0",
    "pino": "^10.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@navikt/aap-felles-prettier": "^5.6.3",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "openapi-typescript": "^7.13.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.5"
  },
  "packageManager": "yarn@4.12.0"
}
